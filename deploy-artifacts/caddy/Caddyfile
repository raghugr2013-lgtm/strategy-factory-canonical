# /opt/caddy/Caddyfile
#
# Production reverse proxy for Strategy Factory.
# Matches the reference Caddyfile in infra/caddy/README.md of the
# canonical repository (raghugr2013-lgtm/strategy-factory-canonical).

{
    # Global options — set the ACME account email for Let's Encrypt
    # renewal notifications. Replace the placeholder before deploy.
    email REPLACE_WITH_LETSENCRYPT_EMAIL@example.com
}

strategy.coinnike.com {
    encode zstd gzip

    # API surface — Phase-1 core + 89 legacy routers all live under /api.
    handle /api/* {
        reverse_proxy factory-backend:8001 {
            transport http {
                dial_timeout    5s
                read_timeout   60s
                write_timeout  60s
            }
            # Preserve the client's original host / IP so the backend's
            # CORS + RBAC + audit-journal logic sees the real caller.
            header_up Host              {host}
            header_up X-Real-IP         {remote}
            header_up X-Forwarded-For   {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Everything else → static frontend (React SPA behind nginx).
    handle {
        reverse_proxy factory-frontend:80
    }

    # Access log for /api/* — useful for the Production Validation Suite
    # and Tier 5 latency correlation.
    log {
        output file /var/log/caddy/strategy-factory.access.log
        format json
    }
}
