# ──────────────────────────────────────────────────────────────────
# Strategy Factory — .env.example  (unified configuration contract)
#
# One contract, two profiles:
#   • This file ships DEV-SAFE values — `cp .env.example .env` then
#     `docker compose up -d` (dev overlay, ./docker-compose.yml) works
#     out of the box on a laptop / lightweight box.
#   • Production uses the SAME variable NAMES with different values
#     and is deployed via `infra/compose/docker-compose.prod.yml` —
#     see docs/CONFIGURATION.md and docs/DEPLOYMENT_OPERATIONS.md.
#
# Never commit a real `.env`. Never put production secrets here.
# ──────────────────────────────────────────────────────────────────

# ── Config contract version ───────────────────────────────────────
CONFIG_VERSION=1

# ── Shared external services ──────────────────────────────────────
# Dev : bundled factory-mongo container (no auth) — this URL.
# Prod: external MongoDB with auth (self-hosted at /opt/factory-mongo,
#       reachable on the shared `vqb-network` as `factory-mongo`).
#       Example production form:
#         mongodb://root:<password>@factory-mongo:27017/?authSource=admin
SHARED_MONGO_URL=mongodb://factory-mongo:27017
FACTORY_DB_NAME=strategy_factory_v1
# Optional — leave blank to skip Redis checks (readiness reports 'skipped').
SHARED_REDIS_URL=

# ── Backend secrets ───────────────────────────────────────────────
# Dev default below is intentionally recognizable; the backend logs a
# warning when it is in use. Prod: 64-char hex (`openssl rand -hex 32`).
JWT_SECRET=dev-only-insecure-jwt-secret-change-in-production
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=7
ADMIN_EMAIL=admin@strategy-factory.local
ADMIN_PASSWORD=admin123
# Dev: "*" is acceptable. Prod: explicit origin list (e.g. https://strategy.coinnike.com).
CORS_ORIGINS=*

# ── VIE (provider keys — leave blank to disable a provider) ──────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
KIMI_API_KEY=

OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_MODEL=deepseek-chat
GROQ_MODEL=llama-3.3-70b-versatile
KIMI_MODEL=kimi-k2

# ── Canonical feature flags ──────────────────────────────────────
# Enumerated in both docker-compose.yml (dev) and
# infra/compose/docker-compose.prod.yml (prod). Compose --env-file
# only supplies interpolation; the backend receives these only if
# they are also present in the `environment:` block. See the compose
# file comments if you add a new flag.
ENABLE_LEGACY_ROUTERS=true
# factory-runner is always on per approved architecture (heartbeat-only
# stub in Phase 0; real APScheduler jobs come online in Phase 5).
ENABLE_FACTORY_RUNNER=true
# Dynamic market universe was on in v01. Turn on in Phase 5.
ENABLE_DYNAMIC_MARKET_UNIVERSE=false

# ── Version metadata (baked into images at build) ────────────────
BUILD_VERSION=1.1.0
BUILD_COMMIT=unknown
BUILD_DATE=1970-01-01

# ── Production-only: DNS / reverse-proxy / image tags ────────────
# Unused by the dev compose file. Production values live in the
# /opt/strategy-factory/.env file that ships with the deploy bundle.
FACTORY_DOMAIN=localhost
# Traefik entrypoints are retained for a possible future migration.
# INERT under Caddy — see infra/traefik/README.md and infra/caddy/README.md.
TRAEFIK_WEBSECURE_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
FACTORY_IMAGE_REPO=strategy-factory
FACTORY_IMAGE_TAG=1.1.0

# ══════════════════════════════════════════════════════════════════
# Phase 1 — Autonomous Factory activation flags (2026-07-23)
# ══════════════════════════════════════════════════════════════════
# All defaults kept OFF so a fresh `cp .env.example .env` reproduces
# the historical dev/prod behaviour byte-identically. Flip these on
# in the PRODUCTION .env (`/opt/strategy-factory/.env`) to activate
# the recovered sibling factory-runner + Unified Autonomous
# Orchestration Engine (Phase B.2). See:
#   - docs/PHASE_1_ACTIVATION_PLAN.md              (execution report)
#   - docs/AUTONOMOUS_CYCLE_HEALTH_DASHBOARD.md   (observability)
#   - docs/IMPLEMENTATION_ROADMAP.md              (why + when)
#
# OBSERVE mode is preserved for every mutating engine. This block
# does NOT enable live trading, autonomous promotions, or any new
# backend endpoint — it only reuses the existing capability graph.

# ── Sibling factory-runner (recovered legacy.factory_runner) ────
# When true, the factory-runner container's app.runner dispatcher
# delegates to legacy.factory_runner._main() and restores the three
# persisted schedulers below. When false, the container stays in the
# heartbeat-only stub loop (Phase-0 behaviour). Idempotent.
FACTORY_RUNNER_OWNS_SCHEDULERS=false

# ── Unified Autonomous Orchestration Engine (Phase B.2) ────────
# Auto-starts on boot when true. Every subordinate scheduler with
# `subordinate_to_orchestrator=true` (default) becomes dormant when
# this is running — no duplicate schedulers, ever.
ORCHESTRATOR_ENABLED=false

# ── Legacy learning scheduler (Phase B / B.1) ───────────────────
# Left OFF by default; the orchestrator supersedes them. If you turn
# ORCHESTRATOR_ENABLED off and want continuous learning, flip
# LEARNING_CONTINUOUS_MODE=true.
LEARNING_SCHEDULER_ENABLED=false
LEARNING_CONTINUOUS_MODE=false
LEARNING_CONTINUOUS_PAIR=EURUSD
LEARNING_CONTINUOUS_TIMEFRAME=H1
LEARNING_CONTINUOUS_STYLE=trend-following

# ── Budget persistence across restarts ──────────────────────────
# BudgetTracker rehydrates from Mongo on boot when true — the daily
# USD cap survives container restarts and rollbacks.
BUDGET_PERSIST=false

# ── Market Intelligence (Phase G) ───────────────────────────────
# Bootstraps 8-observer indexes on boot; refreshed by the
# `market_intelligence_refresh` orchestrator task. Read-only when off.
MI_ENABLED=false

# ── OBSERVE-mode contract (do NOT change without freeze lift) ──
# Meta-Learning writes proposals to its ledger but never applies them
# without operator approval when META_LEARNING_MODE=observe. Same for
# Factory Evaluation. Live-execution is deliberately dormant.
META_LEARNING_MODE=observe
FACTORY_EVAL_MODE=observe
EXEC_ENABLED=false

# ── Sibling runner audit heartbeat cadence ─────────────────────
# Every FACTORY_RUNNER_HEARTBEAT_SEC seconds the sibling writes a
# `factory_runner:heartbeat` row into `audit_log` (in addition to
# refreshing the docker healthcheck file). 300s = 5min is fine.
FACTORY_RUNNER_HEARTBEAT_SEC=300
