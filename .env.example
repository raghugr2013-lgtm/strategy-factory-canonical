# ──────────────────────────────────────────────────────────────────
# Strategy Factory — .env.example
# Copy to `.env` and edit values. Loaded by docker compose.
#
# Production target (as of v1.0.0):
#   https://strategy.coinnike.com   →   Contabo VPS via shared Traefik
# ──────────────────────────────────────────────────────────────────

# ── DNS / Traefik routing ─────────────────────────────────────────
FACTORY_DOMAIN=strategy.coinnike.com
TRAEFIK_WEBSECURE_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# ── Image tag ─────────────────────────────────────────────────────
FACTORY_IMAGE_REPO=strategy-factory
FACTORY_IMAGE_TAG=1.1.0

# ── Version metadata (baked into images at build) ────────────────
BUILD_VERSION=1.1.0
BUILD_COMMIT=unknown
BUILD_DATE=1970-01-01

# ── Shared external services (join vqb-network) ──────────────────
SHARED_MONGO_URL=mongodb://factory_user:CHANGE_ME@mongo:27017/strategy_factory_v1?authSource=admin
FACTORY_DB_NAME=strategy_factory_v1
SHARED_REDIS_URL=

# ── Backend secrets ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_64_CHAR_HEX
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=7
ADMIN_EMAIL=admin@strategy-factory.local
ADMIN_PASSWORD=CHANGE_ME
CORS_ORIGINS=https://strategy.coinnike.com

# ── VIE (provider keys — leave blank to disable a provider) ──────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
KIMI_API_KEY=

OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_MODEL=deepseek-chat
GROQ_MODEL=llama-3.3-70b-versatile
KIMI_MODEL=kimi-k2

# ── Canonical feature flags ──────────────────────────────────────
# ENABLE_LEGACY_ROUTERS is flipped per-module as each phase is recovered.
# Set false in Phase 0; each subsequent module documents its own turn-on.
ENABLE_LEGACY_ROUTERS=true
# factory-runner is always on per approved architecture (heartbeat-only
# stub in Phase 0; real APScheduler jobs come online in Phase 5).
ENABLE_FACTORY_RUNNER=true
# Dynamic market universe was on in v01. Turn on in Phase 5.
ENABLE_DYNAMIC_MARKET_UNIVERSE=false
